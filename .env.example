SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:3000/callback
SPOTIFY_REFRESH_TOKEN=your_refresh_token_here

# Optional — only required if you want the "AI expand my theme" feature.
# Get a free key from https://aistudio.google.com/app/apikey
# IMPORTANT: ensure the GCP project owning this key has billing DISABLED or has a 0 TRY budget
# alert. Otherwise overage above the free tier silently bills.
GEMINI_API_KEY=your_gemini_api_key_here
