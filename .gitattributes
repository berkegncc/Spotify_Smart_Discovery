# Normalize line endings to LF on commit. Windows tools (e.g. .bat) keep CRLF.
* text=auto eol=lf

# Windows scripts must stay CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
